# PostHog Configuration
# Product analytics — error tracking is handled by Sentry
NEXT_PUBLIC_POSTHOG_KEY=your_posthog_project_api_key_here
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Sentry Configuration
# Error tracking, performance, and session replay on errors
# Create project at: https://sentry.io
NEXT_PUBLIC_SENTRY_DSN=https://your_key@o123.ingest.sentry.io/456
NEXT_PUBLIC_SENTRY_RELEASE=local-dev
# CI only (do not expose in client):
# SENTRY_AUTH_TOKEN=your_sentry_auth_token
# SENTRY_ORG=your-org-slug
# SENTRY_PROJECT=yo-self-cardapio

# OpenReplay (optional — disabled automatically when NEXT_PUBLIC_SENTRY_DSN is set)
# Prefer Sentry Replay on errors + PostHog session replay for product analytics
NEXT_PUBLIC_OPENREPLAY_PROJECT_KEY=

# Supabase Edge Functions secrets (set in Supabase Dashboard → Edge Functions → Secrets)
# POSTHOG_API_KEY=phc_...        # LLM $ai_generation events from ai-chat
# POSTHOG_HOST=https://us.i.posthog.com
# SENTRY_DSN=https://...@sentry.io/...
# SENTRY_ENVIRONMENT=production
# GOOGLE_AI_API_KEY=...          # Never expose in NEXT_PUBLIC_* or GitHub Pages static build env

# Site URL (optional)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase Configuration (required for chatbot)
# NEXT_PUBLIC_* values are public in the browser bundle. Use publishable keys only.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Prefer publishable key (sb_publishable_...). Legacy anon JWT still works during migration.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_legacy_anon_jwt_or_publishable_key

# Admin keys for local scripts only (npm run recompress-images). NEVER expose in the client.
# Prefer SUPABASE_URL here so .env.development can point Next.js dev at local Supabase without conflict.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SECRET_KEY=sb_secret_your_key_here
# Edge Functions (Supabase CLI rejects SUPABASE_* custom names — use SB_SECRET_KEY):
# SB_SECRET_KEY=sb_secret_your_key_here

# Google Maps API (required for address autocomplete)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
